{
  "compilerOptions": {
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "paths": {
      "@blurchat/auth": ["./libs/core/auth/src/index.ts"],
      "@blurchat/logger": ["./libs/core/logger/src/index.ts"],
      "@blurchat/logger/instrumentation": ["./libs/core/logger/src/instrumentation.ts"],
      "@blurchat/swagger": ["./libs/core/swagger/src/index.ts"]
    }
  }
}
