# Copy to apps/api/.env and fill in. Loaded by `nx serve` via --env-file-if-exists.
# Railway sets these in the dashboard; this file is local dev only.

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# OpenTelemetry — leave OTEL_EXPORTER_OTLP_ENDPOINT empty to run with tracing OFF.
# Set it to your OTLP base endpoint to export traces/logs/metrics.
# Grafana Cloud: https://otlp-gateway-<zone>.grafana.net/otlp
OTEL_EXPORTER_OTLP_ENDPOINT=
# Auth header for the backend. Grafana Cloud: Basic base64("<instanceID>:<token>")
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64-credentials>
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=blurchat-api
# AlwaysOn (default) | AlwaysOff | traceidratio (+ OTEL_TRACES_SAMPLER_ARG=0.1)
OTEL_TRACES_SAMPLER=AlwaysOn
# Uncomment to debug the exporter
# OTEL_LOG_LEVEL=debug
