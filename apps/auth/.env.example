# Copy to apps/auth/.env and fill in. Loaded by `nx serve` via --env-file-if-exists.

NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# Postgres — Better Auth owns these tables (run: docker compose -f dev-scripts/docker-compose.yml up -d)
DATABASE_URL=postgres://chatarooni:chatarooni@localhost:5432/auth

# Better Auth — generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=<random-secret>
BETTER_AUTH_URL=http://localhost:3001

# Social login — each provider activates only when both of its vars are set.
# Redirect/callback URI to register with the provider:
#   <BETTER_AUTH_URL>/api/auth/callback/{google|facebook}
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# CSRF allowlist (comma-separated origins)
TRUSTED_ORIGINS=http://localhost:5173

# Prod only: parent domain to share the session cookie across subdomains (auth ↔ app), e.g. chatarooni.com
COOKIE_DOMAIN=

# OpenTelemetry — empty = tracing off locally
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64-credentials>
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=chatarooni-auth
